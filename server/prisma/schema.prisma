generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  GURU
  SISWA
}

enum AttendanceStatus {
  HADIR
  SAKIT
  IZIN
  ALPHA
}

model users {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(100)
  email      String    @unique @db.VarChar(150)
  password   String    @db.VarChar(255)
  role       Role      @default(SISWA)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  student       students?
  teacher       teachers?
  notifications notifications[]
}

model students {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  nis          String   @unique @db.VarChar(20)
  full_name    String   @db.VarChar(150)
  gender       String   @db.VarChar(10)
  birth_date   DateTime
  birth_place  String   @db.VarChar(100)
  address      String   @db.Text
  phone        String?  @db.VarChar(20)
  photo        String?  @db.VarChar(255)
  class_id     Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user              users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  class             classes?           @relation(fields: [class_id], references: [id])
  attendance_details attendance_details[]
  grades            grades[]
}

model teachers {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  nip          String   @unique @db.VarChar(20)
  full_name    String   @db.VarChar(150)
  gender       String   @db.VarChar(10)
  birth_date   DateTime
  birth_place  String   @db.VarChar(100)
  address      String   @db.Text
  phone        String?  @db.VarChar(20)
  photo        String?  @db.VarChar(255)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user       users       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subjects   subjects[]
  schedules  schedules[]
  attendance attendance[]
}

model classes {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(50)
  grade        String   @db.VarChar(10)
  academic_year String  @db.VarChar(20)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  students  students[]
  schedules schedules[]
  attendance attendance[]
}

model subjects {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  teacher_id  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  teacher   teachers?   @relation(fields: [teacher_id], references: [id])
  schedules schedules[]
  grades    grades[]
}

model schedules {
  id         Int      @id @default(autoincrement())
  class_id   Int
  subject_id Int
  teacher_id Int
  day        String   @db.VarChar(15)
  start_time String   @db.VarChar(10)
  end_time   String   @db.VarChar(10)
  room       String?  @db.VarChar(50)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class   classes  @relation(fields: [class_id], references: [id])
  subject subjects @relation(fields: [subject_id], references: [id])
  teacher teachers @relation(fields: [teacher_id], references: [id])
}

model attendance {
  id         Int      @id @default(autoincrement())
  class_id   Int
  teacher_id Int
  date       DateTime @db.Date
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class   classes  @relation(fields: [class_id], references: [id])
  teacher teachers @relation(fields: [teacher_id], references: [id])
  details attendance_details[]

  @@unique([class_id, date])
}

model attendance_details {
  id            Int              @id @default(autoincrement())
  attendance_id Int
  student_id    Int
  status        AttendanceStatus @default(HADIR)
  notes         String?          @db.Text
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  attendance attendance @relation(fields: [attendance_id], references: [id], onDelete: Cascade)
  student    students   @relation(fields: [student_id], references: [id])

  @@unique([attendance_id, student_id])
}

model grades {
  id         Int      @id @default(autoincrement())
  student_id Int
  subject_id Int
  semester   Int
  score      Float
  grade_type String   @db.VarChar(30)
  notes      String?  @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  student students @relation(fields: [student_id], references: [id])
  subject subjects @relation(fields: [subject_id], references: [id])
}

model announcements {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(200)
  content    String   @db.Text
  target_role Role?
  is_active  Boolean  @default(true)
  created_by Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(200)
  message    String   @db.Text
  type       String   @db.VarChar(50)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
